

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Job {
  id          String        @id @default(uuid())
  title       String
  company     String
  location    String
  category    String
  description String
  createdAt   DateTime      @default(now())
  applications Application[]
}

model Application {
  id         String   @id @default(uuid())
  jobId      String
  name       String
  email      String
  resumeLink String
  coverNote  String
  createdAt  DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}